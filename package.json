{
  "name": "qore",
  "version": "0.2.5",
  "description": "Ultra-lightweight, single-binary hybrid infrastructure orchestrator with a terminal-native TUI.",
  "type": "module",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "bun run src/index.tsx",
    "start": "bun run src/index.tsx",
    "build": "bash scripts/prebuild.sh && bun build src/index.tsx --compile --outfile qore",
    "tsc": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "infrastructure",
    "orchestrator",
    "tui",
    "terminal",
    "docker",
    "redis",
    "postgres",
    "mongodb",
    "s3",
    "bun",
    "ink",
    "cli",
    "devops"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Kodjaoglanian/qore.git"
  },
  "homepage": "https://github.com/Kodjaoglanian/qore#readme",
  "bugs": {
    "url": "https://github.com/Kodjaoglanian/qore/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@types/pg": "^8.20.0",
    "ink": "^5.0.1",
    "mongodb": "^7.4.0",
    "mysql2": "^3.11.0",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/ssh2": "^1.15.0",
    "bun-types": "^1.1.0",
    "typescript": "^5.5.4"
  }
}
